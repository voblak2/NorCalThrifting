# Copy this to .env and fill in values

# Server
PORT=3001

# CORS — comma-separated origins, or "*" for everything
# In production: https://norcalthrifting.com,https://www.norcalthrifting.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# SQLite file path
DB_PATH=./data/sales.db

# JWT secret — sign with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production. The dev fallback is insecure.
JWT_SECRET=changeme-generate-a-real-secret

# JWT token lifetime (ms-style: 30d, 7d, 24h)
JWT_EXPIRES_IN=30d

# Comma-separated emails that are automatically granted admin role on sign-up.
ADMIN_EMAILS=voblak2@gmail.com

# Cron schedule for auto-refresh (default: 6 AM daily)
# Format: minute hour day month day-of-week
# Examples: "0 */6 * * *" = every 6 hours, "0 6,18 * * *" = 6 AM and 6 PM
CRON_SCHEDULE=0 6 * * *
