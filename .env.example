# Copy this to .env and fill in values

# Server
PORT=3001

# CORS — comma-separated origins, or "*" for everything
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# SQLite file path
DB_PATH=./data/sales.db

# Required to call POST /api/admin/refresh
# Generate a strong random string: `openssl rand -hex 32`
ADMIN_TOKEN=changeme

# Cron schedule for auto-refresh (default: 6 AM daily)
# Format: minute hour day month day-of-week
# Examples: "0 */6 * * *" = every 6 hours, "0 6,18 * * *" = 6 AM and 6 PM
CRON_SCHEDULE=0 6 * * *
