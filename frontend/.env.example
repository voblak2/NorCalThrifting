# Copy this to .env.local for local dev overrides (not needed — Vite proxy handles /api).
# In Vercel, set VITE_API_URL in Project Settings → Environment Variables.

# Render backend URL — set this in Vercel's environment variables after deploying the backend.
# Example: https://norcal-thrifting-api.onrender.com/api
VITE_API_URL=https://your-render-service.onrender.com/api
